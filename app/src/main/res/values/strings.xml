    <string name="guide_title">How to set up streaming on YouTube or Twitch:</string>
    <string name="guide_body">
    <![CDATA[
    📺 <b>YouTube</b>:
    <ul>
        <li>Go to <a href="https://studio.youtube.com">studio.youtube.com</a></li>
        <li>Click on “Go live”</li>
        <li>You will find:
            <ul>
                <li>RTMP URL: <code>rtmp://a.rtmp.youtube.com/live2</code></li>
                <li>Stream key: e.g. <i>abcd-1234-xxxx-zzzz</i></li>
            </ul>
        </li>
        <li>Enter this: <code>rtmp://a.rtmp.youtube.com/live2/abcd-1234-xxxx-zzzz</code></li>
    </ul>

    🎮 <b>Twitch</b>:
    <ul>
        <li>Go to <a href="https://dashboard.twitch.tv">dashboard.twitch.tv</a></li>
        <li>Menu &gt; Settings &gt; Stream</li>
        <li>RTMP URL: <code>rtmp://live.twitch.tv/app</code></li>
        <li>Stream key: e.g. <i>live_12543_...</i></li>
        <li>Enter this: <code>rtmp://live.twitch.tv/app/live_12543_...</code></li>
    </ul>
    ]]>
</string>

    <string name="guide_footer">The RTMP URL is encrypted and not visible to anyone.</string>
