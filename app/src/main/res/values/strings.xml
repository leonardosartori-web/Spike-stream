    <string name="how_to_title">📘 How to use Spikestream</string>

    <!-- App purpose -->
    <string name="app_purpose">
    Spikestream allows you to live stream matches and manage the score in real time, so viewers can follow them from anywhere.
</string>

    <!-- How it works -->
    <string name="how_to_steps_title">How it works</string>
    <string name="step1_title">1. Log in or sign up</string>
    <string name="step1_desc">Log in or create a new account. After logging in, you will be redirected to your list of created matches.</string>

    <string name="step2_title">2. Create a match</string>
    <string name="step2_desc"><![CDATA[Tap the button at the bottom of the match list. Enter the team names and the RTMP address where the match will be streamed.
    For Youtube, you can watch the <a href="https://www.youtube.com/watch?v=M3H3aX1Aoz4">YouTube tutorial</a> to learn how to create an RTMP URL for the live stream.]]></string>

    <string name="step3_title">3. Confirm creation</string>
    <string name="step3_desc">Tap "Create match" to confirm. You will return to the dashboard with all your matches.</string>

    <string name="step4_title">4. Start streaming</string>
    <string name="step4_desc">Open the match from the list. In the match screen you will find two buttons:
    - "Start streaming" to begin the broadcast.
    - "Generate Invite Link" to create a link to share with the person who will update the score (preferably just one person).</string>

