<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config
    - Disables all cleartext (HTTP) traffic globally.
    - All API and WebSocket calls already use https/wss, so this is safe.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
