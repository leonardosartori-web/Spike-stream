<?xml version="1.0" encoding="utf-8"?>
<!--
    Exclude the DataStore file containing the JWT auth token from backup.
    Restoring a backup on another device would grant full session access without re-login.
    API 12+ (uses data-extraction-rules)
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="dataStore" path="user_prefs.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="dataStore" path="user_prefs.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>